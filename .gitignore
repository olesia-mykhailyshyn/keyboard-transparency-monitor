# Byte-compiled / optimized / DLL files
# Python creates .pyc files (compiled bytecode) when it imports modules
# These files are machine-specific and should never be committed to version control
# They will be automatically regenerated when Python runs
*.pyc
__pycache__/
*.py[cod]
*$py.class

