@startuml KTM_RiskAlgorithm
!theme plain
skinparam backgroundColor #FFFFFF
skinparam activity {
    BackgroundColor #E8FFE8
    BorderColor #00AA00
    FontColor #000000
}
skinparam decision {
    BackgroundColor #FFE8F0
    BorderColor #CC0066
    FontColor #000000
}
skinparam note {
    BackgroundColor #FFFFCC
    BorderColor #FF6600
    FontColor #000000
}

title Keyboard Transparency Monitor - Risk Scoring Algorithm\n\n

start
:Pick a process
to analyze;

if (Is in\ntrusted list?) then (YES)
    :Skip process;
    :Score = 0%;
    :Status = SAFE;
    end
else (NO)
    :Initialize score = 0;
endif

note right
    Signal 1: Input Device Access (25%)
end note

:Check process name
for keywords
(keylog, spy, hook, etc);
if (Name match?) then (YES)
    :Add +10 points;
else (NO)
    :Add 0 points;
endif

:Check command line
for input keywords
(GetAsyncKeyState, etc);
if (Cmd match?) then (YES)
    :Add +8 points;
else (NO)
    :Add 0 points;
endif

:Get process handle count;
if (Handle count\n> 500?) then (YES)
    :Add +5 points;
else (NO)
    :Add 0 points;
endif

:Analyze open files
for device access;
if (Device file\nopen?) then (YES)
    :Add +2 points;
else (NO)
    :Add 0 points;
endif

note right
    Signal 2: Blocked Process Relaunch (30%)
end note

:Check blocklist;
:Get relaunch count;

if (Was blocked\nbefore?) then (YES)
    if (Relaunch\ncount > 2?) then (YES)
        :Add +30 points;
        note right: CRITICAL!
    else (1-2 times)
        :Add +15 points;
    endif
else (NO)
    :Add 0 points;
endif

note right
    Signals 3-10: Path, Signature, Age, Visibility, Privilege, Name, Parent, Behavior
end note

:Check install path;
if (Path is\n%TEMP%,\n%DOWNLOADS%?) then (YES)
    :Add +15 points;
else (NO)
    :Add 0 points;
endif

:Check digital signature;
if (Unsigned OR\nunknown CA?) then (YES)
    :Add +12 points;
else (NO)
    :Add 0 points;
endif

:Check process age;
if (Started <\n5 minutes ago?) then (YES)
    :Add +12 points;
else (NO)
    :Add 0 points;
endif

:Check for visible window;
if (No window\nfound?) then (YES)
    :Add +10 points;
else (NO)
    :Add 0 points;
endif

:Check privilege level;
if (Running as\nSYSTEM or\nAdmin?) then (YES)
    :Add +8 points;
else (NO)
    :Add 0 points;
endif

:Check process name;
if (Name looks\nsuspicious?) then (YES)
    :Add +14 points;
else (NO)
    :Add 0 points;
endif

:Check parent process;
if (Parent is\nunusual?) then (YES)
    :Add +8 points;
else (NO)
    :Add 0 points;
endif

:Analyze behavior patterns;
if (Multiple red\nflags detected?) then (YES)
    :Add +18 points;
else (NO)
    :Add 0 points;
endif

:Calculate final score\n(cap at 100%);

if (Score >= 85) then (CRITICAL)
    :Risk Level =\nCRITICAL;
    :Severity =\nImmediate Alert;
    :Recommendation =\nBlock NOW;
elseif (Score >= 70) then (HIGH)
    :Risk Level =\nHIGH;
    :Severity =\nWarning Alert;
    :Recommendation =\nReview & Block;
elseif (Score >= 40) then (MEDIUM)
    :Risk Level =\nMEDIUM;
    :Severity =\nInfo Alert;
    :Recommendation =\nMonitor;
else (LOW)
    :Risk Level =\nLOW;
    :Severity =\nNo Alert;
    :Recommendation =\nNo Action;
endif

:Create RiskAssessment\nobject;

:Generate detected\nsignals list;

:Store in database;

:Emit to UI;

end

note bottom of start
    Input: ProcessMetadata object
    Output: RiskAssessment (score + level)
    Called for each process every 5 seconds
end note

