@startuml KTM_DataFlow
!theme plain
skinparam backgroundColor #FFFFFF
skinparam storage {
    BackgroundColor #FFF8E8
    BorderColor #FF9900
    FontColor #000000
}
skinparam rectangle {
    BackgroundColor #E8FFE8
    BorderColor #00AA00
    FontColor #000000
}
skinparam note {
    BackgroundColor #E8F4FF
    BorderColor #0066CC
    FontColor #000000
}

title Keyboard Transparency Monitor - Data Flow Diagram\n\n

' Data sources
storage "System\nProcesses" as SYS_PROC
storage "File\nSystem" as FILE_SYS
storage "Registry\n(Windows)" as REGISTRY
storage "System\nApis" as SYS_API

' Processing
rectangle "SCAN\nProcesses" as SCAN
rectangle "COLLECT\nMetadata" as COLLECT
rectangle "FILTER\nTrusted" as FILTER
rectangle "ANALYZE\nRisk" as ANALYZE
rectangle "SCORE\nCalculate" as SCORE
rectangle "GENERATE\nAlerts" as GENALERT

' Storage
storage "SQLite\nDatabase" as DB

' Output
rectangle "UPDATE\nUI" as UPDATE
storage "UI\nDisplay" as UI_OUT

' User actions
rectangle "LOG\nActions" as LOG
rectangle "EXPORT\nReports" as EXPORT

note right of SYS_PROC
  Running process list
  (every 5 seconds)
end note

note right of COLLECT
  Extract: PID, name,
  path, cmdline, memory,
  privileges, timestamps
end note

note right of FILTER
  Check whitelist
  Skip trusted procs
end note

note right of ANALYZE
  10-signal detection:
  keyboard indicators,
  paths, signatures,
  privileges, etc.
end note

note right of SCORE
  Weighted scoring
  (0-100 scale)
  Risk level assignment
end note

note right of GENALERT
  High risk (70+)
  Generate alert
  Store in DB
end note

note right of DB
  8 tables:
  processes, detections,
  alerts, blocklist,
  whitelist, actions,
  statistics, system_info
end note

note right of UPDATE
  Thread-safe signal
  to main UI loop
  Update tables/timeline
end note

note right of LOG
  User actions:
  block, trust, export
  All timestamped
end note

SYS_PROC --> SCAN
SYS_API --> SCAN
FILE_SYS --> COLLECT
REGISTRY --> COLLECT
SCAN --> COLLECT
COLLECT --> FILTER
DB --> FILTER
FILTER --> ANALYZE
ANALYZE --> SCORE
SCORE --> GENALERT
GENALERT --> DB
GENALERT --> UPDATE
DB --> UPDATE
UPDATE --> UI_OUT
UI_OUT --> LOG
LOG --> DB
DB --> EXPORT
EXPORT --> UI_OUT

@enduml
