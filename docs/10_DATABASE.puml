@startuml KTM_EntityRelationship
!theme plain
skinparam backgroundColor #FFFFFF
skinparam entity {
    BackgroundColor #E8FFE8
    BorderColor #00AA00
    FontColor #000000
}
skinparam note {
    BackgroundColor #FFFFCC
    BorderColor #FF6600
    FontColor #000000
}

title Keyboard Transparency Monitor - Database Schema (Entity-Relationship)\n\n

entity "🔍 Processes" as processes {
    *id : int <<PK>>
    --
    pid : int <<UNIQUE>>
    name : string
    executable_path : string
    command_line : string
    parent_pid : int
    created_at : datetime
    memory_mb : float
    is_system : boolean
    digital_signature : string
    signature_valid : boolean
}

entity "⚠️ Detections" as detections {
    *detection_id : int <<PK>>
    --
    process_id : int <<FK>>
    detected_at : datetime
    risk_score : float (0-100)
    risk_level : enum (LOW/MED/HIGH/CRIT)
    signals_detected : json array
    keyboard_indicators : json array
    confidence : float
    recommendation : string
}

entity "🚫 Blocked Processes" as blocked_processes {
    *id : int <<PK>>
    --
    process_name : string <<UNIQUE>>
    executable_hash : string
    blocked_at : datetime
    reason : string
    relaunch_count : int
    last_relaunch : datetime
    user_action : string
    notes : string
}

entity "✅ Trusted Processes" as trusted_processes {
    *id : int <<PK>>
    --
    process_name : string <<UNIQUE>>
    executable_hash : string
    trusted_at : datetime
    reason : string
    trusted_by : string
    notes : string
    permanent : boolean
}

entity "📢 Alerts" as alerts {
    *alert_id : int <<PK>>
    --
    process_id : int <<FK>>
    generated_at : datetime
    severity : enum (INFO/WARN/CRIT)
    title : string
    message : string
    details : json object
    read : boolean
    dismissed_at : datetime
    action_taken : string
}

entity "📋 User Actions" as user_actions {
    *action_id : int <<PK>>
    --
    action_type : enum (BLOCK/TRUST/VIEW/EXPORT)
    process_name : string
    timestamp : datetime
    details : json object
    result : string
}

entity "📊 Statistics" as statistics {
    *stat_id : int <<PK>>
    --
    date : date
    total_processes_scanned : int
    threats_detected : int
    alerts_generated : int
    processes_blocked : int
    processes_trusted : int
    avg_scan_time_ms : float
}

entity "💻 System Info" as system_info {
    *info_id : int <<PK>>
    --
    os_name : string
    os_version : string
    os_arch : string
    python_version : string
    ktm_version : string
    first_run : datetime
    last_scan : datetime
    total_detections : int
    database_size_mb : float
}

' Relationships
processes ||--o{ detections : has
processes ||--o{ alerts : triggers
detections ||--o{ user_actions : generates
blocked_processes ||--o{ detections : related_to
trusted_processes ||--o{ processes : whitelists

note right of processes
    Central entity
    Tracks every process
    scanned on system
    Includes signature info
end note

note right of detections
    One-to-many with processes
    Each process may have
    multiple detections
    (history over time)
end note

note right of blocked_processes
    Separate from processes
    Matches by name OR hash
    Tracks relaunch attempts
    Persistent blacklist
end note

note right of trusted_processes
    Permanent whitelist
    Process name matching
    User-defined safe list
end note

note right of alerts
    Generated for high-risk
    processes (score >= 70)
    User can dismiss
    Tied to action history
end note

note right of user_actions
    Audit trail
    All user decisions logged
    Timestamps for forensics
    Export-friendly format
end note

note right of statistics
    Daily aggregates
    Performance metrics
    Trend analysis
    Dashboard data source
end note

note right of system_info
    Singleton table
    System configuration
    Version tracking
    First-run info
end note

